{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "AGENT_HARNESS": "claude-code"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .agent/tools/memory_reflect.py --stdin --skill claude-code --action post-tool --outcome ok --harness claude-code"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python .agent/memory/auto_dream.py"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [],
    "_generated_by_agentic_stack": "permissions.deny is rendered from .agent/protocols/permissions.json during install; run `python .agent/tools/render_claude_settings.py <this-file>` after editing the JSON to refresh."
  }
}
